{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/validatedTwinOutput.schema.json",
  "title": "ValidatedTwinOutput",
  "type": "object",
  "required": ["requestId", "region", "timeUtc", "grid", "pollutants", "derived", "trust", "evidence", "actions", "signature"],
  "properties": {
    "requestId": { "type": "string" },
    "region": { "type": "string" },
    "timeUtc": { "type": "string", "format": "date-time" },
    "grid": {
      "type": "object",
      "required": ["system", "resolution", "cellId"],
      "properties": {
        "system": { "type": "string", "enum": ["H3"] },
        "resolution": { "type": "integer", "minimum": 0, "maximum": 15 },
        "cellId": { "type": "string" }
      },
      "additionalProperties": false
    },
    "pollutants": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["predicted", "unit", "psi", "pi95", "uncertaintyNorm"],
        "properties": {
          "predicted": { "type": "number" },
          "unit": { "type": "string" },
          "psi": { "type": "integer", "minimum": 0, "maximum": 200 },
          "pi95": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "number" } },
          "uncertaintyNorm": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "additionalProperties": false
      }
    },
    "derived": {
      "type": "object",
      "required": ["crs", "tier", "persistence", "exposureNorm", "actionAllowed", "reasonCodes"],
      "properties": {
        "crs": { "type": "number", "minimum": 0, "maximum": 100 },
        "tier": { "type": "string", "enum": ["GREEN", "AMBER", "RED", "PURPLE", "INFO_ONLY", "DATA_GAP"] },
        "persistence": { "type": "number", "minimum": 0, "maximum": 1 },
        "exposureNorm": { "type": "number", "minimum": 0, "maximum": 1 },
        "actionAllowed": { "type": "boolean" },
        "reasonCodes": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "trust": {
      "type": "object",
      "required": ["sensorConfidence", "overallConfidence", "confidenceBreakdown", "driftState"],
      "properties": {
        "sensorConfidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "overallConfidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "confidenceBreakdown": {
          "type": "object",
          "required": ["completeness", "timeliness", "calibration", "crossAgreement", "anomalyRate", "modelUncertainty", "backtestScore", "driftPenalty"],
          "properties": {
            "completeness": { "type": "number", "minimum": 0, "maximum": 1 },
            "timeliness": { "type": "number", "minimum": 0, "maximum": 1 },
            "calibration": { "type": "number", "minimum": 0, "maximum": 1 },
            "crossAgreement": { "type": "number", "minimum": 0, "maximum": 1 },
            "anomalyRate": { "type": "number", "minimum": 0, "maximum": 1 },
            "modelUncertainty": { "type": "number", "minimum": 0, "maximum": 1 },
            "backtestScore": { "type": "number", "minimum": 0, "maximum": 1 },
            "driftPenalty": { "type": "number", "minimum": 0, "maximum": 1 }
          },
          "additionalProperties": false
        },
        "driftState": { "type": "string", "enum": ["NORMAL", "CAUTION", "DEGRADED"] }
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "object",
      "required": ["sources", "versions"],
      "properties": {
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["sourceId", "type", "lastSeenUtc", "freshnessMinutes", "license"],
            "properties": {
              "sourceId": { "type": "string" },
              "type": { "type": "string" },
              "lastSeenUtc": { "type": "string", "format": "date-time" },
              "freshnessMinutes": { "type": "integer", "minimum": 0 },
              "license": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "versions": {
          "type": "object",
          "required": ["normalizer", "twinModel", "rulesEngine"],
          "properties": {
            "normalizer": { "type": "string" },
            "twinModel": { "type": "string" },
            "rulesEngine": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["actionId", "category", "eligible", "priority", "reasonCodes"],
        "properties": {
          "actionId": { "type": "string" },
          "category": { "type": "string" },
          "eligible": { "type": "boolean" },
          "priority": { "type": "number", "minimum": 0, "maximum": 100 },
          "reasonCodes": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "signature": {
      "type": "object",
      "required": ["alg", "payloadSha256", "signatureB64", "publicKeyFingerprint"],
      "properties": {
        "alg": { "type": "string", "enum": ["Ed25519"] },
        "payloadSha256": { "type": "string" },
        "signatureB64": { "type": "string" },
        "publicKeyFingerprint": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
